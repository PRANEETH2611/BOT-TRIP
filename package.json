{
  "name": "bot-trip",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev:backend": "npm run dev --workspace backend",
    "dev:frontend": "npm run dev --workspace frontend",
    "build": "npm run build --workspace frontend",
    "lint": "npm run lint --workspace frontend",
    "check": "npm run check --workspace backend && npm run lint --workspace frontend && npm run build --workspace frontend"
  },
  "engines": {
    "node": ">=20"
  }
}
